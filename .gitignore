# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/

# ---------------------------------------------------------------------------
# Editors / IDEs / OS
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Claude local settings (machine-specific, should not be committed)
# ---------------------------------------------------------------------------
.claude/settings.local.json

# ---------------------------------------------------------------------------
# Node (in case eval-viewer or other tooling pulls deps locally)
# ---------------------------------------------------------------------------
node_modules/

# ---------------------------------------------------------------------------
# Test workspaces (tests/*workspace/)
#
# Each workspace commits its inputs and definitions:
#   evals/evals.json            -- eval set + assertions (source of truth)
#   evals/inputs/               -- input fixtures (PRDs / code under review)
#   skill-snapshot/SKILL.md     -- frozen baseline used as the old_skill config
#   scripts/*.py                -- workspace-local helpers (aggregate, fix)
#
# Everything below is regenerated by `python tests/run_tests.py <workspace>`,
# so it should NOT be in version control.
# ---------------------------------------------------------------------------

# All per-iteration run outputs: executor outputs/, timing.json, grading.json,
# benchmark.{json,md}, review.html, eval_metadata.json copies.
tests/*-workspace/iteration-*/

# Reviewer feedback exported by the skill-creator eval-viewer
tests/**/feedback.json

# Static review HTML if generated outside an iteration directory
tests/**/review.html
